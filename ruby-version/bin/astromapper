#!/usr/bin/env ruby
# -*- mode: ruby -*-

# Allow running directly from a source checkout (before `gem install`) by
# putting this gem's own lib/ on the load path. Harmless once installed.
lib = File.expand_path("../lib", __dir__)
$LOAD_PATH.unshift(lib) unless $LOAD_PATH.include?(lib)

require "astromapper"
Astromapper::Cli.start
